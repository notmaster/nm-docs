{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/authorization-request-v1.schema.json",
  "title": "NM V6 authorization challenge",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "request_type",
    "run_id",
    "nonce",
    "request_digest",
    "spec_hash",
    "config_hash",
    "scope",
    "expected_revision",
    "expires_at"
  ],
  "properties": {
    "schema_version": {"const": "nm-v6/authorization-request-v1"},
    "request_id": {"type": "string", "minLength": 1},
    "request_type": {"enum": ["spec_confirmation", "grant", "approval", "implementation_authorization"]},
    "run_id": {"type": "string", "minLength": 1},
    "nonce": {"type": "string", "minLength": 1},
    "request_digest": {"pattern": "^[0-9a-f]{64}$"},
    "spec_hash": {"pattern": "^[0-9a-f]{64}$"},
    "config_hash": {"pattern": "^[0-9a-f]{64}$"},
    "scope": {"type": "object", "minProperties": 1},
    "expected_revision": {"type": "integer", "minimum": 0},
    "expires_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
