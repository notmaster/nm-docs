{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/evidence-receipt-v1.schema.json",
  "title": "NM V6 core-produced evidence receipt",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_id",
    "evidence_type",
    "producer",
    "run_id",
    "subject_ids",
    "assertions",
    "spec_hash",
    "config_hash",
    "source_commit",
    "candidate_commit",
    "release_source_kind",
    "release_source_commit",
    "release_source_tree",
    "hotfix_reconciliation_gate_id",
    "artifact_digest",
    "environment_id",
    "environment_fingerprint",
    "operation_id",
    "attempt_id",
    "command_action_id",
    "argv_digest",
    "working_directory",
    "started_at",
    "finished_at",
    "exit_code",
    "result",
    "stdout_digest",
    "stderr_digest",
    "tool_versions",
    "producer_version",
    "evaluator_version",
    "redaction_version"
  ],
  "properties": {
    "schema_version": {"const": "nm-v6/evidence-receipt-v1"},
    "evidence_id": {"pattern": "^EVID-[A-Za-z0-9._-]+-[0-9]{3}$"},
    "evidence_type": {"type": "string", "minLength": 1},
    "producer": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "subject_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "assertions": {
      "type": "object",
      "propertyNames": {"type": "string", "minLength": 1},
      "additionalProperties": {"type": "boolean"}
    },
    "spec_hash": {"pattern": "^[0-9a-f]{64}$"},
    "config_hash": {"pattern": "^[0-9a-f]{64}$"},
    "source_commit": {"type": ["string", "null"]},
    "candidate_commit": {"type": ["string", "null"]},
    "release_source_kind": {"type": ["string", "null"], "enum": ["dev", "hotfix_stable", null]},
    "release_source_commit": {"type": ["string", "null"]},
    "release_source_tree": {"type": ["string", "null"]},
    "hotfix_reconciliation_gate_id": {"type": ["string", "null"]},
    "artifact_digest": {"type": ["string", "null"]},
    "environment_id": {"type": ["string", "null"]},
    "environment_fingerprint": {"type": ["string", "null"]},
    "operation_id": {"type": ["string", "null"]},
    "attempt_id": {"type": ["string", "null"]},
    "command_action_id": {"type": ["string", "null"]},
    "argv_digest": {"pattern": "^[0-9a-f]{64}$"},
    "working_directory": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "exit_code": {"type": "integer"},
    "result": {"type": "string", "minLength": 1},
    "stdout_digest": {"pattern": "^[0-9a-f]{64}$"},
    "stderr_digest": {"pattern": "^[0-9a-f]{64}$"},
    "tool_versions": {"type": "object"},
    "producer_version": {"type": "string", "minLength": 1},
    "evaluator_version": {"type": "string", "minLength": 1},
    "redaction_version": {"type": "string", "minLength": 1},
    "collected_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
