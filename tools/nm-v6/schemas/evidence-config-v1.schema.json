  "$id": "https://notmaster.dev/nm-v6/schemas/evidence-config-v1.schema.json",
  "title": "NM V6 evidence storage configuration",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {"const": "nm-v6/evidence-config-v1"},
