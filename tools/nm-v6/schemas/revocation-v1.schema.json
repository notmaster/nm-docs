{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/revocation-v1.schema.json",
  "title": "NM V6 trusted authorization revocation",
  "type": "object",
  "required": [
    "record_type",
    "revocation_id",
    "target_authorization_id",
    "run_id",
    "issued_at",
    "nonce",
    "authenticator_id",
    "authenticator_signature"
  ],
  "properties": {
    "record_type": {"const": "revocation"},
    "revocation_id": {"pattern": "^AUTH-[A-Za-z0-9._-]+-[0-9]{3}$"},
    "target_authorization_id": {"pattern": "^AUTH-[A-Za-z0-9._-]+-[0-9]{3}$"},
    "run_id": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"},
    "nonce": {"type": "string", "minLength": 1},
    "authenticator_id": {"type": "string", "minLength": 1},
    "authenticator_signature": {"type": "string", "minLength": 1, "contentEncoding": "base64"}
  },
  "additionalProperties": false
}
