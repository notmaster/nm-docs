{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/grant-v1.schema.json",
  "title": "NM V6 trusted scoped grant",
  "type": "object",
  "required": [
    "record_type",
    "grant_id",
    "run_id",
    "spec_hash",
    "config_hash",
    "allowed_actions",
    "allowed_environments",
    "allowed_protected_refs",
    "created_by",
    "created_at",
    "expires_at",
    "request_digest",
    "nonce",
    "grant_revision",
    "authenticator_id",
    "authenticator_signature"
  ],
  "properties": {
    "record_type": {"const": "grant"},
    "grant_id": {"pattern": "^AUTH-[A-Za-z0-9._-]+-[0-9]{3}$"},
    "run_id": {"type": "string", "minLength": 1},
    "spec_hash": {"pattern": "^[0-9a-f]{64}$"},
    "config_hash": {"pattern": "^[0-9a-f]{64}$"},
    "allowed_actions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_environments": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_protected_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "request_digest": {"pattern": "^[0-9a-f]{64}$"},
    "nonce": {"type": "string", "minLength": 1},
    "grant_revision": {"type": "integer", "minimum": 0},
    "authenticator_id": {"type": "string", "minLength": 1},
    "authenticator_signature": {"type": "string", "minLength": 1, "contentEncoding": "base64"},
    "one_time": {"type": "boolean"},
    "nonprotected_ref": {"$ref": "#/$defs/nonprotected_ref"}
  },
  "$defs": {
    "nonprotected_ref": {
      "type": "object",
      "required": ["grant_id", "action", "remote", "ref", "expected_sha", "force", "one_time", "expires_at"],
      "properties": {
        "grant_id": {"type": "string", "minLength": 1},
        "action": {"enum": ["push_backup", "delete_remote"]},
        "remote": {"type": "string", "minLength": 1},
        "ref": {"type": "string", "pattern": "^refs/heads/[A-Za-z0-9._/-]+$"},
        "expected_sha": {"pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"},
        "force": {"const": false},
        "one_time": {"const": true},
        "expires_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"required": ["nonprotected_ref"]},
      "then": {
        "required": ["one_time"],
        "properties": {"one_time": {"const": true}}
      }
    }
  ],
  "additionalProperties": false
}
