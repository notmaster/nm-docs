{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/confirmation-v1.schema.json",
  "title": "NM V6 trusted Spec confirmation",
  "type": "object",
  "required": [
    "record_type",
    "confirmation_id",
    "spec_id",
    "version",
    "spec_hash",
    "decision",
    "administrator_identity",
    "issued_at",
    "nonce",
    "authenticator_id",
    "authenticator_signature"
  ],
  "properties": {
    "record_type": {"const": "spec_confirmation"},
    "confirmation_id": {"type": "string", "minLength": 1},
    "spec_id": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "spec_hash": {"pattern": "^[0-9a-f]{64}$"},
    "decision": {"const": "confirmed"},
    "administrator_identity": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"},
    "nonce": {"type": "string", "minLength": 1},
    "authenticator_id": {"type": "string", "minLength": 1},
    "authenticator_signature": {"type": "string", "minLength": 1, "contentEncoding": "base64"}
  },
  "additionalProperties": false
}
