    "v3:check": "python3 tools/nm-v3/nm_v3.py check --target template/v3 --source-dir .",
    "v3:test": "python3 -m unittest discover -s tools/nm-v3/tests -p 'test_*.py'",
    "v4:check": "python3 tools/nm-v4/nm_v4.py check --target template/v4 --source-dir .",
    "v5:check": "python3 tools/nm-v5/nm_v5.py check --target template/v5 --source-dir .",
    "v6:check": "bash tools/nm-v6/python311.sh tools/nm-v6/nm_v6.py repository-check --target .",
    "v6:test": "bash tools/nm-v6/python311.sh tools/nm-v6/nm_v6.py acceptance-test --target .",
    "skill:v3:check": "python3 tools/nm-v3/check_skill.py",
    "skill:v4:check": "python3 /Users/jango/.codex/skills/.system/skill-creator/scripts/quick_validate.py skills/nm-init-project-v4",
    "skill:v5:check": "python3 /Users/jango/.codex/skills/.system/skill-creator/scripts/quick_validate.py skills/nm-init-project-v5",
    "skill:v6:check": "bash tools/nm-v6/python311.sh tools/nm-v6/nm_v6.py check-skill --target skills/nm-init-project-v6"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.49.0",
