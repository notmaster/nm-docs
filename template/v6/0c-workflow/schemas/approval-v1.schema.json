{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/approval-v1.schema.json",
  "title": "NM V6 trusted staged approval",
  "type": "object",
  "required": [
    "record_type",
    "approval_id",
    "run_id",
    "spec_hash",
    "config_hash",
    "allowed_actions",
    "allowed_environments",
    "allowed_protected_refs",
    "created_by",
    "created_at",
    "expires_at",
    "request_digest",
    "nonce",
    "grant_revision",
    "authenticator_id",
    "authenticator_signature"
  ],
  "properties": {
    "record_type": {"const": "approval"},
    "approval_id": {"pattern": "^AUTH-[A-Za-z0-9._-]+-[0-9]{3}$"},
    "run_id": {"type": "string", "minLength": 1},
    "spec_hash": {"pattern": "^[0-9a-f]{64}$"},
    "config_hash": {"pattern": "^[0-9a-f]{64}$"},
    "allowed_actions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_environments": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_protected_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "request_digest": {"pattern": "^[0-9a-f]{64}$"},
    "nonce": {"type": "string", "minLength": 1},
    "grant_revision": {"type": "integer", "minimum": 0},
    "authenticator_id": {"type": "string", "minLength": 1},
    "authenticator_signature": {"type": "string", "minLength": 1, "contentEncoding": "base64"},
    "one_time": {"type": "boolean"}
  },
  "additionalProperties": false
}
