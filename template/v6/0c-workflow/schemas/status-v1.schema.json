{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notmaster.dev/nm-v6/schemas/status-v1.schema.json",
  "title": "NM V6 status projection",
  "type": "object",
  "required": ["schema_version", "run_id", "revision", "state", "mode", "spec_hash", "config_hash", "last_event_sequence", "updated_at", "attention_required"],
  "properties": {
    "schema_version": {"const": "nm-v6/status-v1"},
    "run_id": {"type": "string", "minLength": 1},
    "revision": {"type": "integer", "minimum": 0},
    "state": {"type": "string", "minLength": 1},
    "mode": {"enum": ["staged", "auto"]},
    "spec_hash": {"pattern": "^(?:sha256:)?[0-9a-f]{64}$"},
    "config_hash": {"pattern": "^(?:sha256:)?[0-9a-f]{64}$"},
    "last_event_sequence": {"type": "integer", "minimum": 0},
    "updated_at": {"type": "string", "format": "date-time"},
    "attention_required": {"type": "boolean"},
    "active_phase_id": {"type": ["string", "null"]},
    "active_task_ids": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "object"}
  },
  "additionalProperties": false
}
