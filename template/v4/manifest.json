{
  "schemaVersion": 1,
  "templateVersion": "4.0.0",
  "repository": "https://github.com/notmaster/nm-docs.git",
  "rawBase": "https://raw.githubusercontent.com/notmaster/nm-docs",
  "defaultRef": "main",
  "stateFile": ".nm-template-state.json",
  "directories": [
    ".codex",
    ".codex/hooks",
    ".delete-pending",
    "0a-docs",
    "0a-docs/0a-spec",
    "0a-docs/0b-design",
    "0a-docs/0b-design/prototype",
    "0a-docs/0c-prompts",
    "0b-goals",
    "0c-workflow",
    "0d-scripts"
  ],
  "gitkeepDirectories": [
    ".delete-pending",
    "0a-docs/0a-spec",
    "0a-docs/0b-design/prototype"
  ],
  "templates": [
    {
      "target": ".gitignore",
      "source": "template/v4/.gitignore",
      "policy": "create-only"
    },
    {
      "target": ".markdownlint.json",
      "source": "template/v4/.markdownlint.json",
      "policy": "create-only"
    },
    {
      "target": ".markdownlintignore",
      "source": "template/v4/.markdownlintignore",
      "policy": "create-only"
    },
    {
      "target": "AGENTS.md",
      "source": "template/v4/AGENTS.md",
      "policy": "managed"
    },
    {
      "target": "AGENTS.zh-CN.md",
      "source": "template/v4/AGENTS.zh-CN.md",
      "policy": "managed"
    },
    {
      "target": "CLAUDE.md",
      "source": "template/v4/CLAUDE.md",
      "policy": "managed"
    },
    {
      "target": "GROK.md",
      "source": "template/v4/GROK.md",
      "policy": "managed"
    },
    {
      "target": "PROJECT_STRUCTURE.md",
      "source": "template/v4/PROJECT_STRUCTURE.md",
      "policy": "create-only"
    },
    {
      "target": "README.md",
      "source": "template/v4/README.md",
      "policy": "create-only"
    },
    {
      "target": "package.json",
      "source": "template/v4/package.json",
      "policy": "json-merge",
      "mergeRoots": ["scripts", "devDependencies"]
    },
    {
      "target": ".codex/config.toml",
      "source": "template/v4/.codex/config.toml",
      "policy": "create-only"
    },
    {
      "target": ".codex/hooks/stop-status.sh",
      "source": "template/v4/.codex/hooks/stop-status.sh",
      "policy": "managed"
    },
    {
      "target": "0a-docs/DECISIONS.md",
      "source": "template/v4/0a-docs/DECISIONS.md",
      "policy": "create-only"
    },
    {
      "target": "0a-docs/0c-prompts/write-spec.md",
      "source": "template/v4/0a-docs/0c-prompts/write-spec.md",
      "policy": "create-only"
    },
    {
      "target": "0a-docs/0c-prompts/review-spec.md",
      "source": "template/v4/0a-docs/0c-prompts/review-spec.md",
      "policy": "create-only"
    },
    {
      "target": "0a-docs/0c-prompts/security-review.md",
      "source": "template/v4/0a-docs/0c-prompts/security-review.md",
      "policy": "managed"
    },
    {
      "target": "0b-goals/ROADMAP.md",
      "source": "template/v4/0b-goals/ROADMAP.md",
      "policy": "create-only"
    },
    {
      "target": "0c-workflow/WORKFLOW_V4.md",
      "source": "template/v4/0c-workflow/WORKFLOW_V4.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/SPEC_TEMPLATE.md",
      "source": "template/v4/0c-workflow/SPEC_TEMPLATE.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/AGENT_RECIPES.md",
      "source": "template/v4/0c-workflow/AGENT_RECIPES.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/BRANCHING.md",
      "source": "template/v4/0c-workflow/BRANCHING.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/VERIFY.md",
      "source": "template/v4/0c-workflow/VERIFY.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/RELEASE_CHECKLIST.md",
      "source": "template/v4/0c-workflow/RELEASE_CHECKLIST.md",
      "policy": "managed"
    },
    {
      "target": "0c-workflow/project-profile.yml",
      "source": "template/v4/0c-workflow/project-profile.yml",
      "policy": "create-only"
    },
    {
      "target": "0d-scripts/check-workflow.sh",
      "source": "template/v4/0d-scripts/check-workflow.sh",
      "policy": "managed"
    },
    {
      "target": "0d-scripts/verify.sh",
      "source": "template/v4/0d-scripts/verify.sh",
      "policy": "create-only"
    },
    {
      "target": "0d-scripts/run-goals.py",
      "source": "template/v4/0d-scripts/run-goals.py",
      "policy": "managed"
    },
    {
      "target": "0d-scripts/notify-admin.sh",
      "source": "template/v4/0d-scripts/notify-admin.sh",
      "policy": "create-only"
    },
    {
      "target": "0d-scripts/nm-notify-feishu.sh",
      "source": "template/v4/0d-scripts/nm-notify-feishu.sh",
      "policy": "create-only"
    }
  ],
  "github": {
    "integrationBranch": "dev",
    "stableBranch": "main",
    "labels": [
      {
        "name": "phase-active",
        "color": "1D76DB",
        "description": "阶段正在执行"
      },
      {
        "name": "needs-admin",
        "color": "B60205",
        "description": "需要管理员介入或验收"
      },
      {
        "name": "verify-failed",
        "color": "D93F0B",
        "description": "本地验证失败"
      },
      {
        "name": "ready-for-acceptance",
        "color": "0E8A16",
        "description": "等待管理员验收"
      }
    ]
  }
}
